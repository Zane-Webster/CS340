<h1>Members</h1>

<h2>Current Members</h2>

<table>
	<thead>
		<tr>
			<th>ID</th>
			<th>First Name</th>
			<th>Last Name</th>
			<th>Email</th>
			<th>Phone</th>
			<th>Join Date</th>
			<th>Trainer</th>
		</tr>
	</thead>
	<tbody>
		{{#each members}}
		<tr>
			<td>{{memberID}}</td>
			<td>{{firstName}}</td>
			<td>{{lastName}}</td>
			<td>{{email}}</td>
			<td>{{phoneNumber}}</td>
			<td>{{joinDate}}</td>
			<td>{{trainerName}}</td>
		</tr>
		{{/each}}
	</tbody>
</table>
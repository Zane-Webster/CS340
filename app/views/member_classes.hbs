<h1>Class Enrollments</h1>

<p>
	<button type="button" class="delete-button" onclick="window.location.href='/member-classes/delete-demo'">
		Delete Jamie Enrollment to Demo RESET
	</button>
	<br><br>
	RESET button located at top right of page
</p>

<h2>Current Enrollments</h2>

<table>
	<thead>
		<tr>
			<th>Member</th>
			<th>Class</th>
			<th>Enrollment Date</th>
			<th>Actions</th>
		</tr>
	</thead>
	<tbody>
		{{#each memberClasses}}
		<tr>
			<td>{{memberName}}</td>
			<td>{{className}}</td>
			<td>{{enrollmentDate}}</td>
			<td>
				<div class="action-buttons">
					<button type="button" class="edit-button" onclick="showForm('edit-enrollment-{{memberClassID}}')">Edit</button>
					<button type="button" class="delete-button" onclick="showForm('delete-enrollment-{{memberClassID}}')">Delete</button>
				</div>
			</td>
		</tr>
		{{/each}}
	</tbody>
</table>

<div class="add-button-row">
	<button type="button" onclick="showForm('add-enrollment-form')">Add Enrollment</button>
</div>

<form id="add-enrollment-form" class="crud-form" method="POST" action="/member-classes/add">
	<h2>Add Enrollment</h2>

	<label>Member</label>
	<select name="memberID" required>
		{{#each members}}
		<option value="{{memberID}}">{{firstName}} {{lastName}}</option>
		{{/each}}
	</select>

	<label>Class</label>
	<select name="classID" required>
		{{#each classes}}
		<option value="{{classID}}">{{className}}</option>
		{{/each}}
	</select>

	<label>Enrollment Date</label>
	<input type="date" name="enrollmentDate" required>

	<button type="submit">Add Enrollment</button>
</form>

{{#each memberClasses}}
<form id="edit-enrollment-{{memberClassID}}" class="crud-form" method="POST" action="/member-classes/edit">
	<h2>Edit Enrollment</h2>

	<input type="hidden" name="memberClassID" value="{{memberClassID}}">

	<label>Member</label>
	<select name="newMemberID" required>
		{{#each ../members}}
		<option value="{{memberID}}">{{firstName}} {{lastName}}</option>
		{{/each}}
	</select>

	<label>Class</label>
	<select name="newClassID" required>
		{{#each ../classes}}
		<option value="{{classID}}">{{className}}</option>
		{{/each}}
	</select>

	<label>Enrollment Date</label>
	<input type="date" name="enrollmentDate" value="{{enrollmentDate}}" required>

	<button type="submit">Save Changes</button>
</form>

<form id="delete-enrollment-{{memberClassID}}" class="crud-form" method="POST" action="/member-classes/delete">
	<h2>Delete Enrollment</h2>

	<input type="hidden" name="memberClassID" value="{{memberClassID}}">

	<p>Are you sure you want to remove {{memberName}} from {{className}}?</p>

	<button type="submit" class="delete-button">Delete Enrollment</button>
</form>
{{/each}}
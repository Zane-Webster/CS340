<h1>Memberships</h1>

<h2>Current Memberships</h2>

<table>
	<thead>
		<tr>
			<th>ID</th>
			<th>Membership Name</th>
			<th>Price</th>
			<th>Start Date</th>
			<th>End Date</th>
			<th>Member</th>
			<th>Actions</th>
		</tr>
	</thead>
	<tbody>
		{{#each memberships}}
		<tr>
			<td>{{membershipID}}</td>
			<td>{{membershipName}}</td>
			<td>{{price}}</td>
			<td>{{startDate}}</td>
			<td>{{endDate}}</td>
			<td>{{memberName}}</td>
			<td>
				<div class="action-buttons">
					<button type="button" class="edit-button" onclick="showForm('edit-membership-{{membershipID}}')">Edit</button>
					<button type="button" class="delete-button" onclick="showForm('delete-membership-{{membershipID}}')">Delete</button>
				</div>
			</td>
		</tr>
		{{/each}}
	</tbody>
</table>

<div class="add-button-row">
	<button type="button" onclick="showForm('add-membership-form')">Add Membership</button>
</div>

<form id="add-membership-form" class="crud-form" method="POST" action="/memberships/add">
	<h2>Add Membership</h2>

	<label>Membership Name</label>
	<input type="text" name="membershipName" required>

	<label>Price</label>
	<input type="number" step="0.01" name="price" required>

	<label>Start Date</label>
	<input type="date" name="startDate" required>

	<label>End Date</label>
	<input type="date" name="endDate" required>

	<label>Member</label>
	<select name="memberID" required>
		{{#each members}}
		<option value="{{memberID}}">{{firstName}} {{lastName}}</option>
		{{/each}}
	</select>

	<button type="submit">Add Membership</button>
</form>

{{#each memberships}}
<form id="edit-membership-{{membershipID}}" class="crud-form" method="POST" action="/memberships/edit">
	<h2>Edit Membership</h2>

	<input type="hidden" name="membershipID" value="{{membershipID}}">

	<label>Membership Name</label>
	<input type="text" name="membershipName" value="{{membershipName}}" required>

	<label>Price</label>
	<input type="number" step="0.01" name="price" value="{{price}}" required>

	<label>Start Date</label>
	<input type="date" name="startDate" value="{{startDate}}" required>

	<label>End Date</label>
	<input type="date" name="endDate" value="{{endDate}}" required>

	<label>Member</label>
	<select name="memberID" required>
		{{#each ../members}}
		<option value="{{memberID}}">{{firstName}} {{lastName}}</option>
		{{/each}}
	</select>

	<button type="submit">Save Changes</button>
</form>

<form id="delete-membership-{{membershipID}}" class="crud-form" method="POST" action="/memberships/delete">
	<h2>Delete Membership</h2>

	<input type="hidden" name="membershipID" value="{{membershipID}}">

	<p>Are you sure you want to delete the {{membershipName}} membership for {{memberName}}?</p>

	<button type="submit" class="delete-button">Delete Membership</button>
</form>
{{/each}}